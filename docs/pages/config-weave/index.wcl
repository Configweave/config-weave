// config-weave landing page. `start = true` makes it the page served at `/`.
// Rendered through the stdlib `website` template: the alpha banner and the
// footer are named `region`s (slotted by the template), everything else is
// ordinary page content built from the landing components in
// landing-parts.wcl. The same content degrades to the Markdown / PDF
// backends — no parallel fallback copy needed.

// The wskill registry, discovered from the `include`s in main.wcl: the
// config-weave reference book, plus the deck / training views.
let wskill_books   = included_sites({ folder: "wskills", entry: "wdoc/book/main.wcl" })
let wskill_decks   = included_sites({ folder: "wskills", entry: "wdoc/presentation/main.wcl", prefix: "decks" })
let wskill_courses = included_sites({ folder: "wskills", entry: "wdoc/training/main.wcl", prefix: "training" })

// Extra ` · [deck](…) · [course](…)` links appended to a member's card
// when it ships those views.
let wskill_view_links = fn(n: utf8) -> utf8 {
  let d = join(map(filter(wskill_decks,   fn(x: IncludeEntry) -> bool { x.name == n }), fn(x: IncludeEntry) -> utf8 { $" · [deck](./${x.href})" }), "");
  let c = join(map(filter(wskill_courses, fn(x: IncludeEntry) -> bool { x.name == n }), fn(x: IncludeEntry) -> utf8 { $" · [course](./${x.href})" }), "");
  $"${d}${c}"
}

// One reference card per wskill book (data for `lp_cards`).
let ref_cards = map(wskill_books, fn(s: IncludeEntry) -> LpRefCard {
  {
    name: s.name,
    summary: s.summary ?? "",
    href: $"./${s.href}",
    icon: "lucide.book-open",
    links: wskill_view_links(s.name),
  }
})

// Every published view as a footer link (book, then deck, then course).
let ref_links = flatten([
  map(wskill_books,   fn(s: IncludeEntry) -> LpFootlink { { label: $"${s.name} reference", href: $"./${s.href}" } }),
  map(wskill_decks,   fn(s: IncludeEntry) -> LpFootlink { { label: $"${s.name} deck", href: $"./${s.href}" } }),
  map(wskill_courses, fn(s: IncludeEntry) -> LpFootlink { { label: $"${s.name} course", href: $"./${s.href}" } }),
])

page index { sites = [:config_weave]  title = "config-weave — configuration that ships as a single binary"  start = true
  region "banner" {
    callout "Alpha software." {
      class = ["warning"]
      body  = "config weave is under heavy active development — the playbook/package vocabulary, host API, and CLI can change without notice."
    }
  }

  lp_hero "Configuration that ships as a single binary." {
    badge    = "Written in Rust · single static binary"
    lede     = "config weave reads a typed WCL playbook and either **applies** it to converge a machine — or **checks** that the machine already matches. No agent, no interpreter, no dependencies. Copy one binary onto a Linux or Windows host alongside a playbook folder and run it."
    footnote = "Linux · Windows · statically linked · zero deps"
    lp_cta "Download binaries"  { href = "https://github.com/Configweave/config-weave/releases"  primary = true }
    lp_cta "See how it works"   { href = "#how" }
  }

  lp_terms {
    id = demo
    lp_term "target host" {
      tag    = "apply"
      source = <<'SH'
$ config-weave apply ./sample baseline
gathered 1 fact set(s)

apply 'Sample Baseline' v1.0.0 — play 'baseline'
  ● make-a              configured
  ● secondary/make-b    configured
summary: 2 configured · 0 already configured · 0 error  (0.1s)  exit 0
SH
    }
    lp_term "target host" {
      tag    = "check"
      source = <<'SH'
$ config-weave check ./sample baseline
gathered 1 fact set(s)

check 'Sample Baseline' v1.0.0 — play 'baseline'
  ✓ make-a              already configured
  ✓ secondary/make-b    already configured
summary: 2 already configured · 0 not configured · 0 error  (0.0s)  exit 0
SH
    }
  }

  lp_showcase {
    id      = how
    eyebrow = "How it works"
    heading = "Describe the state. apply it, or check it."
    body    = "A playbook is a typed WCL document — facts to gather, variables, and ordered steps that declare desired state. Each step names a resource like `core.file_present`; its properties are validated against the resource's declared params before anything runs. `apply` converges each out-of-state step idempotently, in dependency order — `requires` sequences steps, `condition` skips ones that don't apply to this host. `check` re-runs the same playbook read-only and reports each step without touching the machine; after a successful apply, a re-check returns *already configured*, even in a fresh process."
    code wcl {
      filename = "sample/playbook.wcl"
      source = <<'WCL'
playbook "Sample Baseline" {
  description = "Create marker files in order"

  gather "os" { from = "core.os_info" }

  vars {
    work_root = "/tmp/config-weave-sample"
    is_linux  = os.family == "linux"
  }

  play "baseline" {
    step "make-a" {
      resource  = "core.file_present"
      condition = is_linux
      properties {
        path    = $"${work_root}/a.txt"
        content = "alpha"
      }
    }
  }
}
WCL
    }
  }

  lp_showcase {
    id      = packages
    eyebrow = "Packages"
    heading = "More gatherers and resources — by dropping in a folder."
    body    = "config weave loads every package under a playbook's `pkgs/` folder. Each package is a folder with a `package.wcl` that registers what it provides — gatherers and resources, namespaced by package: `core.file_present`, `core.os_info`. Each is backed by a wscript script obeying the check → apply → re-check contract. Add a folder and its scripts are available to every play — no registry, no recompile; packages are discovered on the next run. `config-weave init` writes a starter playbook plus an example package, ready to edit."
    code wcl {
      filename = "pkgs/core/package.wcl"
      source = <<'WCL'
package "core" {
  description = "Core sample package"

  gatherer "os_info" {
    script = "gatherers/os_info.wscript"
  }

  resource "file_present" {
    script      = "resources/file_present.wscript"
    concurrency = "parallel"

    param "path" {
      type     = "string"
      required = true
    }
    param "content" {
      type    = "string"
      default = ""
    }
  }
}
WCL
    }
  }

  lp_terms {
    id      = binary
    eyebrow = "Static binary"
    title   = "One file. No runtime."
    lede    = "config weave compiles to a single statically-linked executable. There's nothing to install on the target — no Python, no Ruby, no agent, no shared libraries. Copy the binary to the box, run it, done. The same playbook runs on Linux and Windows."
    lp_term "target host · no toolchain" {
      source = <<'SH'
$ file config-weave
config-weave: ELF 64-bit LSB executable, statically linked

$ ldd config-weave
        not a dynamic executable

$ ./config-weave check ./sample baseline
summary: 2 already configured · 0 not configured · 0 error  exit 0
SH
    }
  }

  lp_features {
    id      = features
    eyebrow = "Features"
    title   = "Built for people who run other people's machines."

    lp_feature "Declarative WCL" {
      icon = "lucide.braces"
      body = "Describe desired state in a typed config language — facts, vars, plays and steps, with real expressions and conditions."
    }
    lp_feature "apply & check" {
      icon = "lucide.circle-check"
      body = "One playbook, two modes: converge a machine to the declared state, or verify it matches without making any change."
    }
    lp_feature "Report-only dry run" {
      icon = "lucide.eye"
      body = "`check` re-runs the playbook read-only and reports each step — what's already configured and what would change — without touching the box."
    }
    lp_feature "Static binaries" {
      icon = "lucide.package"
      body = "A single self-contained executable. No agent, no interpreter, no shared libraries to chase across distros."
    }
    lp_feature "Linux & Windows" {
      icon = "lucide.monitor"
      body = "The same playbook runs on both — one statically-linked binary per platform, cross-compiled and ready to drop onto a fresh box."
    }
    lp_feature "Ordered & conditional" {
      icon = "lucide.workflow"
      body = "`requires` sequences dependent steps into a DAG; `condition` targets steps by gathered facts; containers group related steps."
    }
  }

  lp_cards {
    id      = reference
    eyebrow = "Reference"
    title   = "The manual"
    lede    = "The reference is published as a **wskill** — a self-contained WCL model projected into a readable book, a Claude Code skill, an overview deck, and a hands-on training course."
    cards   = ref_cards
  }

  lp_steps {
    id      = install
    eyebrow = "Install"
    title   = "Up and running in three commands."
    lede    = "Grab a prebuilt binary from the [releases page](https://github.com/Configweave/config-weave/releases) — two binaries plus a checksums file, no installer — and put it on your `PATH`. Then point it at a playbook folder. On Windows, download `config-weave.exe` and run the same commands."

    lp_step "Scaffold a starter playbook" { command = "config-weave init my-playbook" }
    lp_step "Converge a machine"          { command = "config-weave apply my-playbook baseline" }
    lp_step "Verify with no changes"      { command = "config-weave check my-playbook baseline" }
  }

  region "footer" {
    lp_footer {
      brand     = "config weave"
      tagline   = "A Rust configuration tool that ships as a single static binary. apply or check — Linux and Windows."
      copyright = "© 2026 config weave · MIT licensed"
      note      = "built in Rust 🦀"

      lp_footcol "Product" {
        lp_footlink "How it works"  { href = "#how" }
        lp_footlink "Packages"      { href = "#packages" }
        lp_footlink "Static binary" { href = "#binary" }
        lp_footlink "Install"       { href = "#install" }
      }
      lp_footcol "Reference" { links = ref_links }
      lp_footcol "Project" {
        lp_footlink "GitHub"   { href = "https://github.com/Configweave/config-weave" }
        lp_footlink "Releases" { href = "https://github.com/Configweave/config-weave/releases" }
      }
    }
  }
}
