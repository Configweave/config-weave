# config-weave wskill — build recipes.
#
# Self-contained: uses the `wcl` CLI directly, so this wskill stands alone. The
# committed Claude Code skill (.claude/skills/config-weave/) is regenerated with
# `just skill-build` at the repo root; the recipes here render into out/ only.

[default, private]
main:
	@just --list

# Validate the wskill model and every projection template against the schema
[group('check')]
wskill-check:
	wcl check wskill.wcl
	wcl check wdoc/book/main.wcl
	wcl check wdoc/skill/main.wcl
	wcl check wdoc/presentation/main.wcl
	wcl check wdoc/training/main.wcl

# Render the human-readable book projection to out/book
[group('render')]
book-build: wskill-check
	wcl wdoc build wdoc/book/main.wcl --out out/book

# Render the Claude Code skill projection to out/skill
[group('render')]
skill-build: wskill-check
	wcl wdoc skill wdoc/skill/main.wcl --out out/skill

# Render the presentation (overview deck) projection to out/presentation
[group('render')]
presentation-build: wskill-check
	wcl wdoc build wdoc/presentation/main.wcl --out out/presentation

# Render the training (tutorial series) projection to out/training
[group('render')]
training-build: wskill-check
	wcl wdoc build wdoc/training/main.wcl --out out/training

# Render every shipped projection
[group('render')]
render: book-build skill-build presentation-build training-build

# Serve the book projection with live reload
[group('render')]
book-serve:
	wcl wdoc serve wdoc/book/main.wcl

# Remove generated output
[group('clean')]
out-clean:
	rm -rf out
