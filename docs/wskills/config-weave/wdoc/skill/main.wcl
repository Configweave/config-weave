// Skill projection — a Claude Code skill folder over the wskill data model.
//
// Build:  wcl wdoc skill wdoc/skill/main.wcl --out out/skill
//
// The start page becomes SKILL.md; every other page lands under references/.
// SKILL.md's body is the shared `skill_md_body` component — it inlines the curated
// `:ai`/`:both` indexes, linking each pinned note's page directly, so there are no
// per-kind reference pages. config-weave additions over the base template are the
// opt-in `cli` module (references/cli_ref.md) and the `term` glossary
// (references/glossary_ref.md), linked from SKILL.md beneath the curated indexes.

import <wdoc.wcl>
import "../../wskill.wcl"
import "../component/common.wcl"    // UnitRef + shared per-unit sub-sections
import "../component/skill_md.wcl"  // skill_md_body (shared with the book preview)
import "../component/concept.wcl"   // concept_body
import "../component/entity.wcl"    // entity_body
import "../component/fact.wcl"      // fact_body
import "../component/process.wcl"   // process_body
import "../component/type_index.wcl" // shared unit-index page component

// The single topic / skill blocks, bound from their gather lists (see base.wcl).
let topic = head(topics)
let skill = head(skills)

let skill_scripts = skill.skill_scripts
let skill_assets  = skill.skill_assets

// Audience filter — keep the skill lean (drop book-only blocks).
let in_skill   = fn(a: Audience) -> bool { match a { :book => false, _ => true } }
let concepts   = filter(concepts,   fn(c: Concept)   -> bool { in_skill(c.audience) })
let entities   = filter(entities,   fn(e: Entity)    -> bool { in_skill(e.audience) })
let facts      = filter(facts,      fn(f: Fact)      -> bool { in_skill(f.audience) })
let examples   = filter(examples,   fn(x: Example)   -> bool { in_skill(x.audience) })
let terms      = filter(terms,      fn(t: Term)      -> bool { in_skill(t.audience) })
let clis       = filter(clis,       fn(x: Cli)       -> bool { in_skill(x.audience) })
let indexes    = filter(indexes,    fn(x: Index)     -> bool { in_skill(x.audience) })
let procedures = filter(procedures, fn(p: Procedure) -> bool { in_skill(p.audience) })

// Flattened cross-reference rows over the skill's audience-filtered units.
let all_units = flatten([
  map(concepts,   fn(c: Concept)   -> UnitRef { { id: c.id, name: c.name,  href: $"concept_${c.id}", related: c.related } }),
  map(entities,   fn(e: Entity)    -> UnitRef { { id: e.id, name: e.name,  href: $"entity_${e.id}",  related: e.related } }),
  map(facts,      fn(f: Fact)      -> UnitRef { { id: f.id, name: f.title, href: $"fact_${f.id}",    related: f.related } }),
  map(procedures, fn(p: Procedure) -> UnitRef { { id: p.id, name: p.title, href: $"process_${p.id}", related: p.related } }),
])

site skill {
  default_template = :ai_skill
  skill {
    name        = $"${topic.name}"
    description = $"Expertise skill for ${topic.name}: authoring WCL playbooks and packages, writing wscript resource/gatherer/verify scripts, the host API surface, running and testing playbooks. ${topic.summary} Auto-activated when working with playbook.wcl, package.wcl, .wscript scripts, the config-weave CLI, or the testlab."
  }
}

// --- SKILL.md (start page) --------------------------------------------------

page index { sites = [:skill]  start = true
  @schemaless frontmatter {
    wskill_schema_version = $"${schema_version}"
    "allowed-tools"            = skill.allowed_tools
    "disallowed-tools"         = skill.disallowed_tools
    "disable-model-invocation" = skill.disable_model_invocation
  }
  skill_md_body { topic = topic  skill = skill  indexes = indexes  concepts = concepts  entities = entities  facts = facts  procedures = procedures  extra_refs = [] }
  // config-weave additions: the CLI reference and the glossary (not unit pages).
  h2 "More reference"
  wdoc_repeater { each = match len(clis) { 0 => [], _ => [true] }  as = :_cl
    p "- [CLI reference](cli_ref) — every `config-weave` subcommand, its arguments and switches."
  }
  p "- [Glossary](glossary_ref) — config-weave vocabulary."
}

// One page per concept; `related` ids resolve to links to the matching unit's page.
wdoc_repeater { each = concepts  as = :c
  page $"concept_${c.id}" { sites = [:skill]  title = $"${c.name}"
    concept_body { unit = c  examples = examples  all_units = all_units  backlinks = []
      p "[← Back to SKILL.md](index)"
    }
  }
}

wdoc_repeater { each = entities  as = :e
  page $"entity_${e.id}" { sites = [:skill]  title = $"${e.name}"
    entity_body { unit = e  examples = examples  all_units = all_units  backlinks = []
      p "[← Back to SKILL.md](index)"
    }
  }
}

wdoc_repeater { each = facts  as = :f
  page $"fact_${f.id}" { sites = [:skill]  title = $"${f.title}"
    fact_body { unit = f  examples = examples  all_units = all_units  backlinks = []
      p "[← Back to SKILL.md](index)"
    }
  }
}

wdoc_repeater { each = procedures  as = :pr
  page $"process_${pr.id}" { sites = [:skill]  title = $"${pr.title}"
    process_body { unit = pr  all_units = all_units  step_style = "skill"  backlinks = []
      p "[← Back to SKILL.md](index)"
    }
  }
}

// --- references/cli_ref.md — the config-weave CLI command reference -----------
page cli_ref { sites = [:skill]  title = "CLI reference"
  wdoc_repeater { each = clis  as = :c
    h1 $"${c.name} — CLI reference"
    wdoc_repeater { each = match c.description { none => [], d => [d] }  as = :d  p $"${d}" }
    wdoc_repeater { each = match len(c.switches) { 0 => [], _ => [true] }  as = :_gs
      h2 "Global switches"
      table { header = ["Switch", "Value", "Description"]  rows = map(c.switches, fn(sw: CliSwitch) -> list<utf8> { [$"${match sw.short { none => "", s => $"${s}, " }}${sw.long}", sw.value_name ?? "—", sw.description ?? "—"] }) }
    }
    wdoc_repeater { each = c.subcommands  as = :sc
      h2 $"${c.name} ${sc.name}"
      wdoc_repeater { each = match sc.description { none => [], d => [d] }  as = :d  p $"${d}" }
      wdoc_repeater { each = match len(sc.args) { 0 => [], _ => [true] }  as = :_a
        table { header = ["Argument", "Required", "Description"]  rows = map(sc.args, fn(a: CliArg) -> list<utf8> { [$"${a.name}${match a.variadic { true => "…", _ => "" }}", match a.required { true => "required", _ => "optional" }, a.description ?? "—"] }) }
      }
      wdoc_repeater { each = match len(sc.switches) { 0 => [], _ => [true] }  as = :_s
        table { header = ["Switch", "Value", "Description"]  rows = map(sc.switches, fn(sw: CliSwitch) -> list<utf8> { [$"${match sw.short { none => "", s => $"${s}, " }}${sw.long}", sw.value_name ?? "—", sw.description ?? "—"] }) }
      }
      wdoc_repeater { each = sc.examples  as = :ex  code $"${ex.lang ?? "text"}" { source = ex.code } }
    }
  }
}

// --- references/glossary_ref.md — the config-weave vocabulary -----------------
page glossary_ref { sites = [:skill]  title = $"${topic.name} — glossary"
  h1 $"${topic.name} — glossary"
  wdoc_repeater { each = match len(terms) { 0 => [], _ => [true] }  as = :_g
    table {
      header = ["Term", "Definition", "Aliases"]
      rows = map(terms, fn(t: Term) -> list<utf8> { [t.term, t.definition, join(t.aliases, ", ")] })
    }
  }
}
