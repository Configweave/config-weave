// Config Weave package repositories vocabulary (`repos.wcl` schema).

@document
type WeaveReposDoc {
  @children("repo") repos: list<WeaveRepo>
}

@block("repo")
type WeaveRepo {
  @inline(0) name: utf8
  url: utf8
  subdir: utf8?
  runbooks_subdir: utf8?
  branch: utf8?
  sync_cron: utf8?
  webhook_secret: utf8?
}
